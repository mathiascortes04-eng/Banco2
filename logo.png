<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel Admin — Banco Capital RP</title>
<link rel="icon" href="assets/logo.png">
<link rel="stylesheet" href="css/style.css">
</head>
<body>
<div id="toast-wrap"></div>
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<div class="app-shell">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="assets/logo.png" alt="Capital RP">
      <div>
        <span class="gradient-text">Banco Capital</span>
        <small>PANEL ADMINISTRADOR</small>
      </div>
    </div>

    <nav class="nav-group">
      <a class="nav-link" href="dashboard.html"><span class="ic">🏠</span> Mi cuenta</a>
      <a class="nav-link active" data-section="cuentas"><span class="ic">👥</span> Cuentas</a>
      <a class="nav-link" data-section="prestamos"><span class="ic">🏦</span> Préstamos</a>
      <a class="nav-link" data-section="movimientos"><span class="ic">📜</span> Movimientos</a>
    </nav>

    <div class="sidebar-footer">
      <div class="user-chip">
        <div class="avatar" id="user-avatar">AD</div>
        <div class="info">
          <strong id="user-name">Administrador</strong>
          <small>Acceso total</small>
        </div>
      </div>
      <button class="btn btn-ghost btn-block btn-sm" onclick="logout()">Cerrar sesión</button>
    </div>
  </aside>

  <main class="main">
    <div class="mobile-topbar glass">
      <button id="menu-toggle">☰</button>
      <strong class="gradient-text">Panel Admin</strong>
      <img src="assets/logo.png" style="width:30px">
    </div>

    <!-- ============ CUENTAS ============ -->
    <section class="page-section" id="section-cuentas">
      <div class="topbar">
        <div><h1>Gestión de cuentas</h1><p>Crea, edita, bloquea y administra todas las cuentas del banco</p></div>
        <button class="btn btn-primary" id="new-account-btn">+ Crear cuenta</button>
      </div>

      <div class="glass panel">
        <div class="field" style="margin-bottom:16px;max-width:340px;">
          <input type="text" id="search-input" placeholder="Buscar por Discord, nombre, cédula o cuenta...">
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Cuenta</th><th>Discord</th><th>Nombre IC</th><th>Cédula</th>
                <th>Saldo</th><th>Nivel</th><th>Estado</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="accounts-tbody"><tr><td colspan="8" class="empty-state">Cargando cuentas...</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ============ PRÉSTAMOS ============ -->
    <section class="page-section hidden" id="section-prestamos">
      <div class="topbar"><div><h1>Préstamos</h1><p>Todos los préstamos activos, pagados y cancelados</p></div></div>
      <div class="glass panel">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Discord</th><th>Cuenta</th><th>Monto</th><th>Pendiente</th><th>Pago semanal</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody id="loans-tbody"><tr><td colspan="7" class="empty-state">Cargando préstamos...</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ============ MOVIMIENTOS ============ -->
    <section class="page-section hidden" id="section-movimientos">
      <div class="topbar"><div><h1>Movimientos globales</h1><p>Últimos 300 movimientos registrados en todo el banco</p></div></div>
      <div class="glass panel">
        <div id="global-history"><div class="empty-state">Cargando...</div></div>
      </div>
    </section>
  </main>
</div>

<!-- Modal crear/editar cuenta -->
<div class="modal-overlay" id="account-modal">
  <div class="modal-box glass" style="max-width:440px;">
    <h3 id="account-modal-title">Crear cuenta</h3>
    <form id="account-form">
      <div class="field"><label>Usuario de Discord</label><input type="text" id="am-discord" required></div>
      <div class="field"><label>Nombre IC</label><input type="text" id="am-nombre" required></div>
      <div class="field"><label>Cédula IC</label><input type="text" id="am-cedula" required></div>
      <div class="field"><label>Edad IC</label><input type="number" id="am-edad" min="18" max="99" required></div>
      <div class="field"><label id="am-password-label">Contraseña</label><input type="password" id="am-password"></div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost btn-block" id="account-modal-cancel">Cancelar</button>
        <button type="submit" class="btn btn-primary btn-block">Guardar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal dar/quitar dinero -->
<div class="modal-overlay" id="money-modal">
  <div class="modal-box glass">
    <h3 id="money-modal-title">Agregar dinero</h3>
    <p class="text-dim" style="font-size:13px;margin-bottom:14px;" id="money-modal-sub">—</p>
    <div class="field"><label>Monto (₡)</label><input type="number" id="money-amount" min="1"></div>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost btn-block" id="money-modal-cancel">Cancelar</button>
      <button type="button" class="btn btn-primary btn-block" id="money-modal-confirm">Confirmar</button>
    </div>
  </div>
</div>

<script src="js/common.js"></script>
<script src="js/admin.js"></script>
</body>
</html>
